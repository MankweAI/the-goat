# Server Configuration
PORT=3000
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# WhatsApp Configuration
WHATSAPP_SESSION_NAME=the-goat-session

# Pilot Configuration
PILOT_CLASS_CODE=M12-ALPHA-2025
MAX_PILOT_USERS=40

# Notification Configuration
DAILY_REMINDER_TIME=16:00
REMINDER_TIMEZONE=Africa/Johannesburg

# Application Configuration
MESSAGE_DELAY_MIN=2000
MESSAGE_DELAY_MAX=5000
MCQ_RETRY_COOLDOWN_HOURS=24
MAX_MCQ_PER_SESSION=5
